generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  Founder
  Executive
  Operations
  Sales
  Marketing
  Developer
  Support
  Finance
  Contractor
  Client
}

enum UserStatus {
  Invited
  Active
  Suspended
  Archived
}

enum AccessLevel {
  View
  Edit
  Manage
}

enum TaskStatus {
  New
  Assigned
  InProgress
  WaitingOnStephen
  WaitingOnClient
  Completed
  Blocked
}

enum Priority {
  Low
  Medium
  High
  Urgent
}

enum LeadStage {
  New
  Contacted
  Qualified
  Discovery
  Proposal
  Negotiation
  Won
  Lost
  Nurture
}

enum RiskStatus {
  Low
  Medium
  High
}

enum ClientStatus {
  Prospect
  Active
  Paused
  Archived
}

enum ApprovalStatus {
  Open
  InReview
  Approved
  Rejected
  ChangesRequested
  Withdrawn
}

enum DraftCommunicationStatus {
  Draft
  PendingApproval
  ChangesRequested
  Approved
  Sent
  Cancelled
}

enum DailyReportStatus {
  Draft
  Submitted
  Reviewed
  ChangesRequested
}

enum KnowledgeStatus {
  Draft
  Published
  Archived
}

enum FeedbackType {
  Bug
  WorkflowIssue
  FeatureRequest
  ConfusingInterface
  MissingInformation
  NovaSuggestion
  MissionControlSuggestion
  Other
}

enum FeedbackStatus {
  New
  Reviewing
  Planned
  InProgress
  Completed
  Declined
}

enum FileVisibility {
  Private
  AssignedUsers
  FounderOnly
  RoleVisible
}

enum AcademyContentType {
  Learning
  SOP
  Policy
  Knowledge
  ToolGuide
}

enum AcademyAssignmentStatus {
  Assigned
  InProgress
  Completed
  Paused
  Archived
}

enum AcademyQuestionStatus {
  Open
  Answered
  Resolved
  ConvertedToFAQ
}

enum AcademyUrgency {
  Normal
  Urgent
}

enum KnowledgeQuestionType {
  MultipleChoice
  TrueFalse
  ScenarioChoice
  ShortResponse
}

enum KnowledgeAttemptStatus {
  Passed
  Failed
  FounderReview
}

enum ModuleResourceType {
  InternalLink
  ExternalLink
  DownloadableFile
  VideoUrl
  Screenshot
  Template
  Checklist
  RelatedSOP
  RelatedKnowledgeArticle
}

enum SOPCategory {
  Operations
  ClientOperations
  LeadOperations
  MeetingsExecutiveSupport
  ContentMarketingSupport
}

model User {
  id                       String                   @id @default(cuid())
  name                     String
  preferredName            String?
  email                    String                   @unique
  emailVerified            Boolean                  @default(false)
  passwordHash             String?
  image                    String?
  status                   UserStatus               @default(Invited)
  timezone                 String                   @default("America/Chicago")
  roleId                   String
  role                     Role                     @relation(fields: [roleId], references: [id])
  sessions                 Session[]
  accounts                 Account[]
  assignedTasks            Task[]                   @relation("TaskOwner")
  createdTasks             Task[]                   @relation("TaskCreator")
  approvedTasks            Task[]                   @relation("TaskApprover")
  assignedLeads            Lead[]
  clientAccess             ClientAccess[]
  leadAccess               LeadAccess[]
  fileAccess               FileAccess[]
  onboardingCompletions    OnboardingCompletion[]
  ownedArticles            KnowledgeArticle[]
  authoredAnnouncements    Announcement[]
  announcementReads        AnnouncementRead[]
  approvalsOwned           Approval[]               @relation("ApprovalRequester")
  approvalsApproved        Approval[]               @relation("ApprovalDecider")
  authoredDrafts           DraftCommunication[]     @relation("DraftAuthor")
  approvedDrafts           DraftCommunication[]     @relation("DraftApprover")
  sentDrafts               DraftCommunication[]     @relation("DraftSender")
  reports                  DailyReport[]
  reviewedReports          DailyReport[]            @relation("ReportReviewer")
  comments                 Comment[]
  activity                 Activity[]
  notifications            Notification[]
  auditLogs                AuditLog[]
  files                    FileAsset[]
  feedback                 FeedbackSubmission[]
  trialSettings            TrialSettings?
  learningPathAssignments  LearningPathAssignment[] @relation("AcademyLearner")
  assignedLearningPaths    LearningPathAssignment[] @relation("AcademyAssigner")
  academyCompletions       ModuleCompletion[]
  policyAcknowledgements   PolicyAcknowledgement[]
  academyNotes             EmployeeModuleNote[]
  academyQuestions         EmployeeQuestion[]       @relation("AcademyQuestionLearner")
  answeredAcademyQuestions EmployeeQuestion[]       @relation("AcademyQuestionAnswerer")
  academyProgress          AcademyProgress[]
  academyActivity          AcademyActivity[]
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  archivedAt               DateTime?

  @@index([status])
  @@index([roleId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, expiresAt])
}

model Account {
  id           String    @id @default(cuid())
  userId       String
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  idToken      String?
  expiresAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model VerificationToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  type      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, type])
}

model Role {
  id          String           @id @default(cuid())
  name        RoleName         @unique
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Client {
  id                  String               @id @default(cuid())
  company             String
  status              ClientStatus         @default(Prospect)
  services            String[]
  riskStatus          RiskStatus           @default(Low)
  nextFollowUp        DateTime?
  operationalNotes    String?
  founderOnlyNotes    String?
  contacts            Contact[]
  projects            Project[]
  tasks               Task[]
  leads               Lead[]
  files               FileAsset[]
  access              ClientAccess[]
  draftCommunications DraftCommunication[]
  approvals           Approval[]
  communications      Communication[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  archivedAt          DateTime?

  @@index([riskStatus])
  @@index([status])
}

model ClientAccess {
  userId    String
  clientId  String
  access    AccessLevel @default(View)
  grantedBy String?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@id([userId, clientId])
  @@index([clientId])
}

model Contact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  email     String?
  phone     String?
  title     String?
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id                  String               @id @default(cuid())
  clientId            String?
  company             String
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  serviceInterest     String
  estimatedValue      Decimal?
  approvedValue       Decimal?
  stage               LeadStage            @default(New)
  lastContact         DateTime?
  followUpDate        DateTime?
  nextAction          String?
  draftMessage        String?
  notes               String?
  approvalRequired    Boolean              @default(false)
  approvalStatus      ApprovalStatus?
  assignedUserId      String?
  client              Client?              @relation(fields: [clientId], references: [id])
  assignedUser        User?                @relation(fields: [assignedUserId], references: [id])
  access              LeadAccess[]
  approvals           Approval[]
  files               FileAsset[]
  draftCommunications DraftCommunication[]
  tasks               Task[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  archivedAt          DateTime?

  @@index([stage, followUpDate])
  @@index([assignedUserId])
}

model LeadAccess {
  userId    String
  leadId    String
  access    AccessLevel @default(View)
  grantedBy String?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead      Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@id([userId, leadId])
  @@index([leadId])
}

model Project {
  id          String      @id @default(cuid())
  clientId    String?
  name        String
  description String?
  status      String
  timeline    String?
  client      Client?     @relation(fields: [clientId], references: [id])
  tasks       Task[]
  milestones  Milestone[]
  files       FileAsset[]
  comments    Comment[]
  activity    Activity[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  archivedAt  DateTime?
}

model Milestone {
  id        String    @id @default(cuid())
  projectId String
  title     String
  dueDate   DateTime?
  completed Boolean   @default(false)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Task {
  id               String      @id @default(cuid())
  title            String
  description      String?
  status           TaskStatus  @default(New)
  priority         Priority    @default(Medium)
  dueDate          DateTime?
  projectId        String?
  clientId         String?
  leadId           String?
  ownerId          String?
  approverId       String?
  createdById      String?
  approvalRequired Boolean     @default(false)
  internalNotes    String?
  completedAt      DateTime?
  archivedAt       DateTime?
  project          Project?    @relation(fields: [projectId], references: [id])
  client           Client?     @relation(fields: [clientId], references: [id])
  lead             Lead?       @relation(fields: [leadId], references: [id])
  owner            User?       @relation("TaskOwner", fields: [ownerId], references: [id])
  approver         User?       @relation("TaskApprover", fields: [approverId], references: [id])
  createdBy        User?       @relation("TaskCreator", fields: [createdById], references: [id])
  comments         Comment[]
  files            FileAsset[]
  approvals        Approval[]
  activity         Activity[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([ownerId, status])
  @@index([dueDate])
  @@index([clientId])
  @@index([leadId])
}

model OnboardingModule {
  id               String                 @id @default(cuid())
  title            String
  description      String
  content          String
  estimatedMinutes Int
  required         Boolean                @default(true)
  sortOrder        Int
  published        Boolean                @default(true)
  visibleToRoles   RoleName[]             @default([])
  completions      OnboardingCompletion[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([published, sortOrder])
}

model OnboardingCompletion {
  userId      String
  moduleId    String
  completedAt DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  module      OnboardingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([userId, moduleId])
  @@index([userId, completedAt])
}

model LearningPath {
  id                    String                   @id @default(cuid())
  sourceKey             String                   @unique
  slug                  String                   @unique
  title                 String
  description           String
  visibleToRoles        RoleName[]               @default([])
  active                Boolean                  @default(true)
  version               Int                      @default(1)
  estimatedTotalMinutes Int                      @default(0)
  seedManaged           Boolean                  @default(true)
  founderReviewRequired Boolean                  @default(false)
  createdById           String?
  updatedById           String?
  courses               Course[]
  assignments           LearningPathAssignment[]
  progress              AcademyProgress[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  archivedAt            DateTime?

  @@index([active])
}

model LearningPathAssignment {
  id           String                  @id @default(cuid())
  pathId       String
  userId       String
  assignedById String?
  assignedAt   DateTime                @default(now())
  dueDate      DateTime?
  status       AcademyAssignmentStatus @default(Assigned)
  startedAt    DateTime?
  completedAt  DateTime?
  required     Boolean                 @default(true)
  customNotes  String?
  path         LearningPath            @relation(fields: [pathId], references: [id], onDelete: Cascade)
  user         User                    @relation("AcademyLearner", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy   User?                   @relation("AcademyAssigner", fields: [assignedById], references: [id])

  @@unique([pathId, userId])
  @@index([userId, status])
}

model Course {
  id          String         @id @default(cuid())
  sourceKey   String         @unique
  slug        String         @unique
  pathId      String
  title       String
  description String
  sortOrder   Int
  required    Boolean        @default(true)
  published   Boolean        @default(true)
  seedManaged Boolean        @default(true)
  path        LearningPath   @relation(fields: [pathId], references: [id], onDelete: Cascade)
  modules     CourseModule[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([pathId, sortOrder])
}

model CourseModule {
  id                      String                  @id @default(cuid())
  sourceKey               String                  @unique
  slug                    String                  @unique
  courseId                String
  title                   String
  summary                 String
  learningObjectives      String[]
  body                    String
  sortOrder               Int
  estimatedMinutes        Int
  required                Boolean                 @default(true)
  contentType             AcademyContentType      @default(Learning)
  published               Boolean                 @default(true)
  audienceRoles           RoleName[]              @default([])
  version                 Int                     @default(1)
  acknowledgementRequired Boolean                 @default(false)
  acknowledgementText     String?
  knowledgeCheckRequired  Boolean                 @default(false)
  minimumPassingScore     Int                     @default(80)
  ownerId                 String?
  lastReviewed            DateTime?
  nextReviewDate          DateTime?
  founderReviewRequired   Boolean                 @default(false)
  seedManaged             Boolean                 @default(true)
  archivedAt              DateTime?
  course                  Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sections                ModuleSection[]
  resources               ModuleResource[]
  knowledgeCheck          KnowledgeCheck?
  completions             ModuleCompletion[]
  acknowledgements        PolicyAcknowledgement[]
  notes                   EmployeeModuleNote[]
  questions               EmployeeQuestion[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([courseId, sortOrder])
  @@index([published, contentType])
}

model ModuleSection {
  id        String       @id @default(cuid())
  moduleId  String
  heading   String
  body      String
  sortOrder Int
  module    CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, sortOrder])
}

model ModuleResource {
  id          String             @id @default(cuid())
  moduleId    String
  type        ModuleResourceType
  label       String
  url         String?
  description String?
  sortOrder   Int                @default(0)
  module      CourseModule       @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId, sortOrder])
}

model KnowledgeCheck {
  id               String                   @id @default(cuid())
  moduleId         String                   @unique
  passingScore     Int                      @default(80)
  unlimitedRetries Boolean                  @default(true)
  module           CourseModule             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions        KnowledgeCheckQuestion[]
  attempts         KnowledgeCheckAttempt[]
}

model KnowledgeCheckQuestion {
  id                    String                 @id @default(cuid())
  checkId               String
  type                  KnowledgeQuestionType
  prompt                String
  explanation           String
  sortOrder             Int
  requiredFounderReview Boolean                @default(false)
  check                 KnowledgeCheck         @relation(fields: [checkId], references: [id], onDelete: Cascade)
  options               KnowledgeCheckOption[]

  @@unique([checkId, sortOrder])
}

model KnowledgeCheckOption {
  id         String                 @id @default(cuid())
  questionId String
  label      String
  correct    Boolean                @default(false)
  sortOrder  Int
  question   KnowledgeCheckQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, sortOrder])
}

model KnowledgeCheckAttempt {
  id            String                 @id @default(cuid())
  checkId       String
  userId        String
  answers       Json
  score         Int
  status        KnowledgeAttemptStatus
  submittedAt   DateTime               @default(now())
  reviewerId    String?
  reviewerNotes String?
  check         KnowledgeCheck         @relation(fields: [checkId], references: [id], onDelete: Cascade)

  @@index([checkId, userId, submittedAt])
}

model ModuleCompletion {
  id                      String       @id @default(cuid())
  userId                  String
  moduleId                String
  moduleVersion           Int
  acknowledgementAccepted Boolean      @default(false)
  knowledgeCheckAttemptId String?
  founderReviewedAt       DateTime?
  completedAt             DateTime     @default(now())
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  module                  CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId, moduleVersion])
  @@index([userId, completedAt])
}

model PolicyAcknowledgement {
  id             String       @id @default(cuid())
  userId         String
  moduleId       String
  moduleVersion  Int
  statement      String
  acknowledgedAt DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  module         CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId, moduleVersion])
}

model EmployeeModuleNote {
  id        String       @id @default(cuid())
  userId    String
  moduleId  String
  body      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  module    CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model EmployeeQuestion {
  id               String                @id @default(cuid())
  userId           String
  moduleId         String?
  urgency          AcademyUrgency        @default(Normal)
  status           AcademyQuestionStatus @default(Open)
  question         String
  answer           String?
  answeredById     String?
  answeredAt       DateTime?
  resolvedAt       DateTime?
  convertedToFaqAt DateTime?
  user             User                  @relation("AcademyQuestionLearner", fields: [userId], references: [id], onDelete: Cascade)
  answeredBy       User?                 @relation("AcademyQuestionAnswerer", fields: [answeredById], references: [id])
  module           CourseModule?         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([userId, status])
  @@index([moduleId, status])
}

model SOPArticle {
  id                    String      @id @default(cuid())
  sourceKey             String      @unique
  slug                  String      @unique
  title                 String
  category              SOPCategory
  purpose               String
  owner                 String
  audienceRoles         RoleName[]  @default([])
  trigger               String
  requiredInputs        String[]
  body                  String
  approvalPoints        String[]
  escalationConditions  String[]
  completionCriteria    String[]
  relatedTemplates      String[]
  version               Int         @default(1)
  published             Boolean     @default(true)
  seedManaged           Boolean     @default(true)
  founderReviewRequired Boolean     @default(false)
  lastReviewed          DateTime?
  nextReviewDate        DateTime?
  steps                 SOPStep[]
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  archivedAt            DateTime?

  @@index([published, category])
}

model SOPStep {
  id          String     @id @default(cuid())
  sopId       String
  stepNumber  Int
  title       String
  instruction String
  sop         SOPArticle @relation(fields: [sopId], references: [id], onDelete: Cascade)

  @@unique([sopId, stepNumber])
}

model KnowledgeArticleVersion {
  id          String           @id @default(cuid())
  articleId   String
  version     Int
  title       String
  body        String
  changedById String?
  article     KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@unique([articleId, version])
}

model ContentAudience {
  id          String   @id @default(cuid())
  contentType String
  contentId   String
  role        RoleName
  required    Boolean  @default(false)

  @@unique([contentType, contentId, role])
  @@index([role])
}

model RequiredReadingAssignment {
  id           String    @id @default(cuid())
  userId       String
  contentType  String
  contentId    String
  assignedById String?
  dueDate      DateTime?
  completedAt  DateTime?
  required     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@unique([userId, contentType, contentId])
  @@index([userId, completedAt])
}

model AcademyProgress {
  id                        String       @id @default(cuid())
  userId                    String
  pathId                    String
  percent                   Int          @default(0)
  estimatedMinutesRemaining Int          @default(0)
  updatedAt                 DateTime     @updatedAt
  user                      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  path                      LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@unique([userId, pathId])
}

model AcademyActivity {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  targetType String
  targetId   String?
  target     String
  metadata   Json?
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}

model KnowledgeArticle {
  id              String                    @id @default(cuid())
  title           String
  category        String
  body            String
  status          KnowledgeStatus           @default(Draft)
  ownerId         String?
  version         Int                       @default(1)
  visibleToRoles  RoleName[]
  requiredReading Boolean                   @default(false)
  relatedLinks    Json?
  archivedAt      DateTime?
  owner           User?                     @relation(fields: [ownerId], references: [id])
  versions        KnowledgeArticleVersion[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([status, category])
}

model FileAsset {
  id         String              @id @default(cuid())
  name       String
  mimeType   String
  size       Int
  storageKey String
  visibility FileVisibility      @default(AssignedUsers)
  folder     String
  version    Int                 @default(1)
  uploaderId String
  clientId   String?
  leadId     String?
  projectId  String?
  taskId     String?
  approvalId String?
  reportId   String?
  feedbackId String?
  uploader   User                @relation(fields: [uploaderId], references: [id])
  client     Client?             @relation(fields: [clientId], references: [id])
  lead       Lead?               @relation(fields: [leadId], references: [id])
  project    Project?            @relation(fields: [projectId], references: [id])
  task       Task?               @relation(fields: [taskId], references: [id])
  approval   Approval?           @relation(fields: [approvalId], references: [id])
  report     DailyReport?        @relation(fields: [reportId], references: [id])
  feedback   FeedbackSubmission? @relation(fields: [feedbackId], references: [id])
  access     FileAccess[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  archivedAt DateTime?
}

model FileAccess {
  userId String
  fileId String
  access AccessLevel @default(View)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  file   FileAsset   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([userId, fileId])
}

model DailyReport {
  id                 String            @id @default(cuid())
  userId             String
  reportDate         DateTime
  shiftStart         DateTime?
  shiftEnd           DateTime?
  breakMinutes       Int               @default(0)
  hoursWorked        Decimal
  completed          String
  inProgress         String
  clientUpdates      String?
  leadActivity       String?
  meetings           String?
  blockers           String?
  waitingOnStephen   String?
  recommendations    String?
  tomorrowPriorities String
  status             DailyReportStatus @default(Draft)
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewerId         String?
  reviewerNotes      String?
  user               User              @relation(fields: [userId], references: [id])
  reviewer           User?             @relation("ReportReviewer", fields: [reviewerId], references: [id])
  files              FileAsset[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([userId, reportDate])
  @@index([userId, reportDate])
  @@index([status])
}

model Approval {
  id                   String              @id @default(cuid())
  summary              String
  context              String
  businessImpact       String
  recommendation       String
  deadline             DateTime?
  priority             Priority            @default(Medium)
  status               ApprovalStatus      @default(Open)
  decision             String?
  decisionNotes        String?
  decisionAt           DateTime?
  requesterId          String
  deciderId            String?
  taskId               String?
  clientId             String?
  leadId               String?
  draftCommunicationId String?
  requester            User                @relation("ApprovalRequester", fields: [requesterId], references: [id])
  decider              User?               @relation("ApprovalDecider", fields: [deciderId], references: [id])
  task                 Task?               @relation(fields: [taskId], references: [id])
  client               Client?             @relation(fields: [clientId], references: [id])
  lead                 Lead?               @relation(fields: [leadId], references: [id])
  draftCommunication   DraftCommunication? @relation(fields: [draftCommunicationId], references: [id])
  comments             Comment[]
  files                FileAsset[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([status, deadline])
  @@index([requesterId])
}

model DraftCommunication {
  id               String                   @id @default(cuid())
  authorId         String
  clientId         String?
  leadId           String?
  channel          String
  recipient        String
  subject          String?
  body             String
  purpose          String
  status           DraftCommunicationStatus @default(Draft)
  approverId       String?
  approvalComments String?
  approvedAt       DateTime?
  sentAt           DateTime?
  sentById         String?
  outcome          String?
  author           User                     @relation("DraftAuthor", fields: [authorId], references: [id])
  client           Client?                  @relation(fields: [clientId], references: [id])
  lead             Lead?                    @relation(fields: [leadId], references: [id])
  approver         User?                    @relation("DraftApprover", fields: [approverId], references: [id])
  sentBy           User?                    @relation("DraftSender", fields: [sentById], references: [id])
  approvals        Approval[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

model Announcement {
  id            String             @id @default(cuid())
  title         String
  body          String
  category      String
  priority      Priority           @default(Medium)
  pinned        Boolean            @default(false)
  publishAt     DateTime           @default(now())
  expiresAt     DateTime?
  audienceRoles RoleName[]
  archivedAt    DateTime?
  authorId      String
  author        User               @relation(fields: [authorId], references: [id])
  readReceipts  AnnouncementRead[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model AnnouncementRead {
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([announcementId, userId])
}

model FeedbackSubmission {
  id              String         @id @default(cuid())
  type            FeedbackType
  title           String
  description     String
  pageOrFeature   String?
  severity        Priority       @default(Medium)
  attachmentId    String?
  submittedById   String
  status          FeedbackStatus @default(New)
  founderResponse String?
  submittedBy     User           @relation(fields: [submittedById], references: [id])
  files           FileAsset[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model TrialSettings {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  trialStartDate          DateTime
  trialEndDate            DateTime
  weeklyHourTarget        Decimal
  maximumTrialHours       Decimal
  hourlyRateCents         Int
  primaryTimezone         String   @default("Asia/Manila")
  requiredOverlapTimezone String   @default("America/Chicago")
  status                  String   @default("Active")
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

model Comment {
  id         String    @id @default(cuid())
  body       String
  authorId   String
  taskId     String?
  projectId  String?
  approvalId String?
  author     User      @relation(fields: [authorId], references: [id])
  task       Task?     @relation(fields: [taskId], references: [id])
  project    Project?  @relation(fields: [projectId], references: [id])
  approval   Approval? @relation(fields: [approvalId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Activity {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String
  taskId    String?
  projectId String?
  actor     User?    @relation(fields: [actorId], references: [id])
  task      Task?    @relation(fields: [taskId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  ipAddress String?
  userAgent String?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([entity, entityId, createdAt])
  @@index([userId, createdAt])
}

model Communication {
  id         String   @id @default(cuid())
  clientId   String
  channel    String
  summary    String
  occurredAt DateTime
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}
