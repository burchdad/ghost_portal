generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  Founder
  Executive
  Operations
  Sales
  Marketing
  Developer
  Support
  Finance
  Contractor
  Client
}

enum UserStatus {
  Invited
  Active
  Suspended
  Archived
}

enum AccessLevel {
  View
  Edit
  Manage
}

enum TaskStatus {
  New
  Assigned
  InProgress
  WaitingOnStephen
  WaitingOnClient
  Completed
  Blocked
}

enum Priority {
  Low
  Medium
  High
  Urgent
}

enum LeadStage {
  New
  Contacted
  Qualified
  Discovery
  Proposal
  Negotiation
  Won
  Lost
  Nurture
}

enum RiskStatus {
  Low
  Medium
  High
}

enum ClientStatus {
  Prospect
  Active
  Paused
  Archived
}

enum ApprovalStatus {
  Open
  InReview
  Approved
  Rejected
  ChangesRequested
  Withdrawn
}

enum DraftCommunicationStatus {
  Draft
  PendingApproval
  ChangesRequested
  Approved
  Sent
  Cancelled
}

enum DailyReportStatus {
  Draft
  Submitted
  Reviewed
  ChangesRequested
}

enum KnowledgeStatus {
  Draft
  Published
  Archived
}

enum FeedbackType {
  Bug
  WorkflowIssue
  FeatureRequest
  ConfusingInterface
  MissingInformation
  NovaSuggestion
  MissionControlSuggestion
  Other
}

enum FeedbackStatus {
  New
  Reviewing
  Planned
  InProgress
  Completed
  Declined
}

enum FileVisibility {
  Private
  AssignedUsers
  FounderOnly
  RoleVisible
}

model User {
  id                       String                   @id @default(cuid())
  name                     String
  preferredName            String?
  email                    String                   @unique
  emailVerified            Boolean                  @default(false)
  passwordHash             String?
  image                    String?
  status                   UserStatus               @default(Invited)
  timezone                 String                   @default("America/Chicago")
  roleId                   String
  role                     Role                     @relation(fields: [roleId], references: [id])
  sessions                 Session[]
  accounts                 Account[]
  assignedTasks            Task[]                   @relation("TaskOwner")
  createdTasks             Task[]                   @relation("TaskCreator")
  approvedTasks            Task[]                   @relation("TaskApprover")
  assignedLeads            Lead[]
  clientAccess             ClientAccess[]
  leadAccess               LeadAccess[]
  fileAccess               FileAccess[]
  onboardingCompletions    OnboardingCompletion[]
  ownedArticles            KnowledgeArticle[]
  authoredAnnouncements    Announcement[]
  announcementReads        AnnouncementRead[]
  approvalsOwned           Approval[]               @relation("ApprovalRequester")
  approvalsApproved        Approval[]               @relation("ApprovalDecider")
  authoredDrafts           DraftCommunication[]     @relation("DraftAuthor")
  approvedDrafts           DraftCommunication[]     @relation("DraftApprover")
  sentDrafts               DraftCommunication[]     @relation("DraftSender")
  reports                  DailyReport[]
  reviewedReports          DailyReport[]            @relation("ReportReviewer")
  comments                 Comment[]
  activity                 Activity[]
  notifications            Notification[]
  auditLogs                AuditLog[]
  files                    FileAsset[]
  feedback                 FeedbackSubmission[]
  trialSettings            TrialSettings?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  archivedAt               DateTime?

  @@index([status])
  @@index([roleId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, expiresAt])
}

model Account {
  id           String    @id @default(cuid())
  userId       String
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  idToken      String?
  expiresAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique
  type      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email, type])
}

model Role {
  id          String           @id @default(cuid())
  name        RoleName         @unique
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Client {
  id                    String          @id @default(cuid())
  company               String
  status                ClientStatus    @default(Prospect)
  services              String[]
  riskStatus            RiskStatus      @default(Low)
  nextFollowUp          DateTime?
  operationalNotes      String?
  founderOnlyNotes      String?
  contacts              Contact[]
  projects              Project[]
  tasks                 Task[]
  leads                 Lead[]
  files                 FileAsset[]
  access                ClientAccess[]
  draftCommunications   DraftCommunication[]
  approvals             Approval[]
  communications        Communication[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  archivedAt            DateTime?

  @@index([riskStatus])
  @@index([status])
}

model ClientAccess {
  userId    String
  clientId  String
  access    AccessLevel @default(View)
  grantedBy String?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@id([userId, clientId])
  @@index([clientId])
}

model Contact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  email     String?
  phone     String?
  title     String?
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id               String               @id @default(cuid())
  clientId         String?
  company          String
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  serviceInterest  String
  estimatedValue   Decimal?
  approvedValue    Decimal?
  stage            LeadStage            @default(New)
  lastContact      DateTime?
  followUpDate     DateTime?
  nextAction       String?
  draftMessage     String?
  notes            String?
  approvalRequired Boolean              @default(false)
  approvalStatus   ApprovalStatus?
  assignedUserId   String?
  client           Client?              @relation(fields: [clientId], references: [id])
  assignedUser     User?                @relation(fields: [assignedUserId], references: [id])
  access           LeadAccess[]
  approvals        Approval[]
  files            FileAsset[]
  draftCommunications DraftCommunication[]
  tasks            Task[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  archivedAt       DateTime?

  @@index([stage, followUpDate])
  @@index([assignedUserId])
}

model LeadAccess {
  userId    String
  leadId    String
  access    AccessLevel @default(View)
  grantedBy String?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead      Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@id([userId, leadId])
  @@index([leadId])
}

model Project {
  id           String       @id @default(cuid())
  clientId     String?
  name         String
  description  String?
  status       String
  timeline     String?
  client       Client?      @relation(fields: [clientId], references: [id])
  tasks        Task[]
  milestones   Milestone[]
  files        FileAsset[]
  comments     Comment[]
  activity     Activity[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  archivedAt   DateTime?
}

model Milestone {
  id        String    @id @default(cuid())
  projectId String
  title     String
  dueDate   DateTime?
  completed Boolean   @default(false)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Task {
  id               String      @id @default(cuid())
  title            String
  description      String?
  status           TaskStatus  @default(New)
  priority         Priority    @default(Medium)
  dueDate          DateTime?
  projectId        String?
  clientId         String?
  leadId           String?
  ownerId          String?
  approverId       String?
  createdById      String?
  approvalRequired Boolean     @default(false)
  internalNotes    String?
  completedAt      DateTime?
  archivedAt       DateTime?
  project          Project?    @relation(fields: [projectId], references: [id])
  client           Client?     @relation(fields: [clientId], references: [id])
  lead             Lead?       @relation(fields: [leadId], references: [id])
  owner            User?       @relation("TaskOwner", fields: [ownerId], references: [id])
  approver         User?       @relation("TaskApprover", fields: [approverId], references: [id])
  createdBy        User?       @relation("TaskCreator", fields: [createdById], references: [id])
  comments         Comment[]
  files            FileAsset[]
  approvals        Approval[]
  activity         Activity[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([ownerId, status])
  @@index([dueDate])
  @@index([clientId])
  @@index([leadId])
}

model OnboardingModule {
  id          String                  @id @default(cuid())
  title       String
  description String
  content     String
  estimatedMinutes Int
  required    Boolean                 @default(true)
  sortOrder   Int
  published   Boolean                 @default(true)
  visibleToRoles RoleName[]
  completions OnboardingCompletion[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([published, sortOrder])
}

model OnboardingCompletion {
  userId      String
  moduleId    String
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module      OnboardingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([userId, moduleId])
  @@index([userId, completedAt])
}

model KnowledgeArticle {
  id              String          @id @default(cuid())
  title           String
  category        String
  body            String
  status          KnowledgeStatus @default(Draft)
  ownerId         String?
  version         Int             @default(1)
  visibleToRoles  RoleName[]
  requiredReading Boolean         @default(false)
  relatedLinks    Json?
  archivedAt      DateTime?
  owner           User?           @relation(fields: [ownerId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status, category])
}

model FileAsset {
  id          String         @id @default(cuid())
  name        String
  mimeType    String
  size        Int
  storageKey  String
  visibility  FileVisibility @default(AssignedUsers)
  folder      String
  version     Int            @default(1)
  uploaderId  String
  clientId    String?
  leadId      String?
  projectId   String?
  taskId      String?
  approvalId  String?
  reportId    String?
  feedbackId  String?
  uploader    User           @relation(fields: [uploaderId], references: [id])
  client      Client?        @relation(fields: [clientId], references: [id])
  lead        Lead?          @relation(fields: [leadId], references: [id])
  project     Project?       @relation(fields: [projectId], references: [id])
  task        Task?          @relation(fields: [taskId], references: [id])
  approval    Approval?      @relation(fields: [approvalId], references: [id])
  report      DailyReport?   @relation(fields: [reportId], references: [id])
  feedback    FeedbackSubmission? @relation(fields: [feedbackId], references: [id])
  access      FileAccess[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  archivedAt  DateTime?
}

model FileAccess {
  userId String
  fileId String
  access AccessLevel @default(View)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  file   FileAsset   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([userId, fileId])
}

model DailyReport {
  id                 String            @id @default(cuid())
  userId             String
  reportDate         DateTime
  shiftStart         DateTime?
  shiftEnd           DateTime?
  breakMinutes       Int               @default(0)
  hoursWorked        Decimal
  completed          String
  inProgress         String
  clientUpdates      String?
  leadActivity       String?
  meetings           String?
  blockers           String?
  waitingOnStephen   String?
  recommendations    String?
  tomorrowPriorities String
  status             DailyReportStatus @default(Draft)
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewerId         String?
  reviewerNotes      String?
  user               User              @relation(fields: [userId], references: [id])
  reviewer           User?             @relation("ReportReviewer", fields: [reviewerId], references: [id])
  files              FileAsset[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([userId, reportDate])
  @@index([userId, reportDate])
  @@index([status])
}

model Approval {
  id                    String         @id @default(cuid())
  summary               String
  context               String
  businessImpact        String
  recommendation        String
  deadline              DateTime?
  priority              Priority       @default(Medium)
  status                ApprovalStatus @default(Open)
  decision              String?
  decisionNotes         String?
  decisionAt            DateTime?
  requesterId           String
  deciderId             String?
  taskId                String?
  clientId              String?
  leadId                String?
  draftCommunicationId  String?
  requester             User           @relation("ApprovalRequester", fields: [requesterId], references: [id])
  decider               User?          @relation("ApprovalDecider", fields: [deciderId], references: [id])
  task                  Task?          @relation(fields: [taskId], references: [id])
  client                Client?        @relation(fields: [clientId], references: [id])
  lead                  Lead?          @relation(fields: [leadId], references: [id])
  draftCommunication    DraftCommunication? @relation(fields: [draftCommunicationId], references: [id])
  comments              Comment[]
  files                 FileAsset[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([status, deadline])
  @@index([requesterId])
}

model DraftCommunication {
  id               String                   @id @default(cuid())
  authorId         String
  clientId         String?
  leadId           String?
  channel          String
  recipient        String
  subject          String?
  body             String
  purpose          String
  status           DraftCommunicationStatus @default(Draft)
  approverId       String?
  approvalComments String?
  approvedAt       DateTime?
  sentAt           DateTime?
  sentById         String?
  outcome          String?
  author           User                     @relation("DraftAuthor", fields: [authorId], references: [id])
  client           Client?                  @relation(fields: [clientId], references: [id])
  lead             Lead?                    @relation(fields: [leadId], references: [id])
  approver         User?                    @relation("DraftApprover", fields: [approverId], references: [id])
  sentBy           User?                    @relation("DraftSender", fields: [sentById], references: [id])
  approvals        Approval[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

model Announcement {
  id           String             @id @default(cuid())
  title        String
  body         String
  category     String
  priority     Priority           @default(Medium)
  pinned       Boolean            @default(false)
  publishAt    DateTime           @default(now())
  expiresAt    DateTime?
  audienceRoles RoleName[]
  archivedAt   DateTime?
  authorId     String
  author       User               @relation(fields: [authorId], references: [id])
  readReceipts AnnouncementRead[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model AnnouncementRead {
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([announcementId, userId])
}

model FeedbackSubmission {
  id              String         @id @default(cuid())
  type            FeedbackType
  title           String
  description     String
  pageOrFeature   String?
  severity        Priority      @default(Medium)
  attachmentId    String?
  submittedById   String
  status          FeedbackStatus @default(New)
  founderResponse String?
  submittedBy     User          @relation(fields: [submittedById], references: [id])
  files           FileAsset[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model TrialSettings {
  id                      String     @id @default(cuid())
  userId                  String     @unique
  trialStartDate          DateTime
  trialEndDate            DateTime
  weeklyHourTarget        Decimal
  maximumTrialHours       Decimal
  hourlyRateCents         Int
  primaryTimezone         String     @default("Asia/Manila")
  requiredOverlapTimezone String     @default("America/Chicago")
  status                  String     @default("Active")
  user                    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

model Comment {
  id         String    @id @default(cuid())
  body       String
  authorId   String
  taskId     String?
  projectId  String?
  approvalId String?
  author     User      @relation(fields: [authorId], references: [id])
  task       Task?     @relation(fields: [taskId], references: [id])
  project    Project?  @relation(fields: [projectId], references: [id])
  approval   Approval? @relation(fields: [approvalId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Activity {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String
  taskId    String?
  projectId String?
  actor     User?    @relation(fields: [actorId], references: [id])
  task      Task?    @relation(fields: [taskId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  ipAddress String?
  userAgent String?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([entity, entityId, createdAt])
  @@index([userId, createdAt])
}

model Communication {
  id         String   @id @default(cuid())
  clientId   String
  channel    String
  summary    String
  occurredAt DateTime
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}
