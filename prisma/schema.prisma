generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  Founder
  Executive
  Operations
  Sales
  Marketing
  Developer
  Support
  Finance
  Contractor
  Client
}

enum UserStatus {
  Invited
  Active
  Suspended
  Archived
}

enum AccessLevel {
  View
  Edit
  Manage
}

enum TaskStatus {
  New
  Assigned
  InProgress
  WaitingOnStephen
  WaitingOnClient
  Completed
  Blocked
}

enum Priority {
  Low
  Medium
  High
  Urgent
}

enum LeadStage {
  New
  Researching
  ReadyToCall
  Attempted
  Connected
  Contacted
  Qualified
  Interested
  FollowUp
  MeetingScheduled
  Discovery
  Proposal
  Negotiation
  Won
  Lost
  Nurture
  DoNotContact
}

enum LeadInterestLevel {
  Unknown
  Low
  Possible
  Interested
  StrongInterest
  MeetingRequested
}

enum LeadHandoffStatus {
  OpsOnly
  SalesReadyNeedsDiscovery
  QualifiedAwaitingFounderReview
  SentToMissionControl
  ReturnedForInformation
}

enum RiskStatus {
  Low
  Medium
  High
}

enum ClientStatus {
  Prospect
  Active
  Paused
  Archived
}

enum ApprovalStatus {
  Open
  InReview
  Approved
  Rejected
  ChangesRequested
  Withdrawn
}

enum DraftCommunicationStatus {
  Draft
  PendingApproval
  ChangesRequested
  Approved
  Sent
  Cancelled
}

enum DailyReportStatus {
  Draft
  Submitted
  Reviewed
  ChangesRequested
}

enum KnowledgeStatus {
  Draft
  Published
  Archived
}

enum FeedbackType {
  Bug
  EmployeeOnboardingBeta
  ConfusingWording
  BrokenWorkflow
  PermissionIssue
  TrainingIssue
  PricingQuestion
  ServiceQuestion
  ProcessImprovement
  WorkflowIssue
  FeatureRequest
  ConfusingInterface
  MissingInformation
  NovaSuggestion
  MissionControlSuggestion
  Other
}

enum WorkShiftStatus {
  ClockedIn
  OnBreak
  Completed
  AwaitingCorrection
}

enum TimeCorrectionStatus {
  Requested
  UnderReview
  Approved
  Rejected
}

enum AcademyQuestionDifficulty {
  Beginner
  Intermediate
  Advanced
}

enum AcademyQuestionPublishStatus {
  Draft
  Approved
  Retired
}

enum FeedbackStatus {
  New
  Reviewing
  Planned
  InProgress
  Completed
  Declined
}

enum FileVisibility {
  Private
  AssignedUsers
  FounderOnly
  RoleVisible
}

enum AcademyContentType {
  Learning
  SOP
  Policy
  Knowledge
  ToolGuide
}

enum AcademyAssignmentStatus {
  Assigned
  InProgress
  Completed
  Paused
  Archived
}

enum AcademyQuestionStatus {
  Open
  Answered
  Resolved
  ConvertedToFAQ
}

enum AcademyUrgency {
  Normal
  Urgent
}

enum KnowledgeQuestionType {
  MultipleChoice
  TrueFalse
  ScenarioChoice
  ShortResponse
}

enum KnowledgeAttemptStatus {
  Passed
  Failed
  FounderReview
  NeedsReview
}

enum ModuleResourceType {
  InternalLink
  ExternalLink
  DownloadableFile
  VideoUrl
  Screenshot
  Template
  Checklist
  RelatedSOP
  RelatedKnowledgeArticle
}

enum SOPCategory {
  Operations
  ClientOperations
  LeadOperations
  MeetingsExecutiveSupport
  ContentMarketingSupport
}

enum ServiceCategory {
  Websites
  WebsiteCare
  AIAutomation
  CustomAISystems
  LeadGeneration
  SEOAEO_GEO
  Marketing
  SocialMedia
  Applications
  DigitalBusinessCards
  Consulting
  FractionalLeadership
  CustomDevelopment
}

enum PricingStatus {
  Provisional
  UnderReview
  Approved
  FounderManagedRequired
  CustomScope
  Retired
  Inactive
}

enum OfferType {
  GrowthPartnership
  StandaloneService
  ProductSubscription
  CustomEnterpriseEngagement
}

enum PriceDisplayMode {
  Fixed
  Range
  FounderReviewRequired
  CustomPricing
}

enum PricingBasis {
  Project
  MonthlyRetainer
  Subscription
  PerUnit
  UsageBased
  Custom
}

enum FinancingStatus {
  FinancingUnavailable
  FinancingAvailable
  FinancingApplicationRequired
  ThirdPartyFinancing
  CustomFinancingTerms
}

enum PriceFrequency {
  OneTime
  Monthly
  Annual
  PerUnitMonthly
  UsageBased
}

model User {
  id                       String                        @id @default(cuid())
  name                     String
  preferredName            String?
  email                    String                        @unique
  emailVerified            Boolean                       @default(false)
  passwordHash             String?
  image                    String?
  status                   UserStatus                    @default(Invited)
  timezone                 String                        @default("America/Chicago")
  roleId                   String
  role                     Role                          @relation(fields: [roleId], references: [id])
  sessions                 Session[]
  accounts                 Account[]
  assignedTasks            Task[]                        @relation("TaskOwner")
  createdTasks             Task[]                        @relation("TaskCreator")
  approvedTasks            Task[]                        @relation("TaskApprover")
  assignedLeads            Lead[]
  createdLeads             Lead[]                        @relation("LeadCreator")
  clientAccess             ClientAccess[]
  leadAccess               LeadAccess[]
  fileAccess               FileAccess[]
  onboardingCompletions    OnboardingCompletion[]
  ownedArticles            KnowledgeArticle[]
  authoredAnnouncements    Announcement[]
  announcementReads        AnnouncementRead[]
  approvalsOwned           Approval[]                    @relation("ApprovalRequester")
  approvalsApproved        Approval[]                    @relation("ApprovalDecider")
  authoredDrafts           DraftCommunication[]          @relation("DraftAuthor")
  approvedDrafts           DraftCommunication[]          @relation("DraftApprover")
  sentDrafts               DraftCommunication[]          @relation("DraftSender")
  callActivities           CallActivity[]
  reports                  DailyReport[]
  reviewedReports          DailyReport[]                 @relation("ReportReviewer")
  comments                 Comment[]
  activity                 Activity[]
  notifications            Notification[]
  auditLogs                AuditLog[]
  files                    FileAsset[]
  feedback                 FeedbackSubmission[]
  trialSettings            TrialSettings?
  servicesUpdated          ServiceOffering[]             @relation("ServiceUpdatedBy")
  approvedServiceOfferings ServiceOffering[]             @relation("ServiceApprovedBy")
  pricingHistory           PricingHistory[]              @relation("PricingHistoryChangedBy")
  packagesUpdated          ServicePackage[]              @relation("PackageUpdatedBy")
  pricingRequestsOwned     PricingApprovalRequest[]      @relation("PricingApprovalRequester")
  pricingRequestsDecided   PricingApprovalRequest[]      @relation("PricingApprovalDecider")
  pricingAcknowledgements  PricingAcknowledgement[]
  workShifts               WorkShift[]
  timeCorrectionsRequested TimeCorrectionRequest[]       @relation("TimeCorrectionRequester")
  timeCorrectionsReviewed  TimeCorrectionRequest[]       @relation("TimeCorrectionReviewer")
  learningPathAssignments  LearningPathAssignment[]      @relation("AcademyLearner")
  assignedLearningPaths    LearningPathAssignment[]      @relation("AcademyAssigner")
  academyCompletions       ModuleCompletion[]
  knowledgeCheckUnlocks    KnowledgeCheckAttemptUnlock[] @relation("KnowledgeCheckUnlockLearner")
  grantedKnowledgeUnlocks  KnowledgeCheckAttemptUnlock[] @relation("KnowledgeCheckUnlockManager")
  policyAcknowledgements   PolicyAcknowledgement[]
  academyNotes             EmployeeModuleNote[]
  academyQuestions         EmployeeQuestion[]            @relation("AcademyQuestionLearner")
  answeredAcademyQuestions EmployeeQuestion[]            @relation("AcademyQuestionAnswerer")
  academyProgress          AcademyProgress[]
  academyActivity          AcademyActivity[]
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt
  archivedAt               DateTime?

  @@index([status])
  @@index([roleId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, expiresAt])
}

model Account {
  id           String    @id @default(cuid())
  userId       String
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  idToken      String?
  expiresAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model VerificationToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  type      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, type])
}

model Role {
  id          String           @id @default(cuid())
  name        RoleName         @unique
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Client {
  id                  String               @id @default(cuid())
  company             String
  status              ClientStatus         @default(Prospect)
  services            String[]
  riskStatus          RiskStatus           @default(Low)
  nextFollowUp        DateTime?
  operationalNotes    String?
  founderOnlyNotes    String?
  contacts            Contact[]
  projects            Project[]
  tasks               Task[]
  leads               Lead[]
  files               FileAsset[]
  access              ClientAccess[]
  draftCommunications DraftCommunication[]
  approvals           Approval[]
  communications      Communication[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  archivedAt          DateTime?

  @@index([riskStatus])
  @@index([status])
}

model ClientAccess {
  userId    String
  clientId  String
  access    AccessLevel @default(View)
  grantedBy String?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@id([userId, clientId])
  @@index([clientId])
}

model Contact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  email     String?
  phone     String?
  title     String?
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id                     String                   @id @default(cuid())
  clientId               String?
  company                String
  contactName            String?
  jobTitle               String?
  contactEmail           String?
  contactPhone           String?
  website                String?
  industry               String?
  location               String?
  timezone               String?
  leadSource             String?
  createdById            String?
  whySelected            String?
  existingTechnology     String?
  websiteStatus          String?
  marketingStatus        String?
  aiOpportunity          String?
  suggestedService       String?
  conversationAngle      String?
  businessAge            String?
  employeeCount          String?
  approximateRevenue     String?
  currentWebsite         String?
  currentLeadFlow        String?
  currentCrm             String?
  currentAdvertising     String?
  currentAutomation      String?
  mainPainPoint          String?
  urgency                String?
  budgetComfort          String?
  decisionMakerStatus    String?
  desiredOutcome         String?
  internalCapacity       String?
  numberOfLocations      String?
  regulatedIndustry      Boolean                  @default(false)
  existingVendor         String?
  preferredOfferType     OfferType?
  recommendedGhostOffer  String?
  recommendedServiceId   String?
  needDiscovered         String[]                 @default([])
  interestLevel          LeadInterestLevel        @default(Unknown)
  qualificationSummary   String?
  appointmentStatus      String?
  handoffStatus          LeadHandoffStatus        @default(OpsOnly)
  missionControlStatus   String                   @default("Not Sent")
  missionControlStage    String?
  missionControlPayload  Json?
  missionControlSyncedAt DateTime?
  needsStephenReview     Boolean                  @default(false)
  needsStephenReason     String?
  valueSuggestionRange   String?
  previousEmailHistory   String?
  previousCallHistory    String?
  serviceInterest        String
  estimatedValue         Decimal?
  approvedValue          Decimal?
  stage                  LeadStage                @default(New)
  callResult             String?
  lastContact            DateTime?
  followUpDate           DateTime?
  appointmentDate        DateTime?
  nextAction             String?
  draftMessage           String?
  notes                  String?
  approvalRequired       Boolean                  @default(false)
  doNotContact           Boolean                  @default(false)
  approvalStatus         ApprovalStatus?
  assignedUserId         String?
  client                 Client?                  @relation(fields: [clientId], references: [id])
  createdBy              User?                    @relation("LeadCreator", fields: [createdById], references: [id])
  assignedUser           User?                    @relation(fields: [assignedUserId], references: [id])
  recommendedService     ServiceOffering?         @relation("LeadRecommendedService", fields: [recommendedServiceId], references: [id])
  access                 LeadAccess[]
  approvals              Approval[]
  files                  FileAsset[]
  draftCommunications    DraftCommunication[]
  tasks                  Task[]
  callActivities         CallActivity[]
  pricingRequests        PricingApprovalRequest[]
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  archivedAt             DateTime?

  @@index([stage, followUpDate])
  @@index([assignedUserId])
  @@index([leadSource])
  @@index([handoffStatus, missionControlStatus])
}

model CallActivity {
  id                  String    @id @default(cuid())
  leadId              String
  userId              String
  outcome             String
  summary             String
  personReached       String?
  decisionMakerStatus String?
  objection           String?
  callbackRequested   Boolean   @default(false)
  doNotContact        Boolean   @default(false)
  recordingReference  String?
  nextAction          String?
  followUpDate        DateTime?
  occurredAt          DateTime  @default(now())
  lead                Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user                User      @relation(fields: [userId], references: [id])
  createdAt           DateTime  @default(now())

  @@index([leadId, occurredAt])
  @@index([userId, occurredAt])
}

model ServiceOffering {
  id                          String                   @id @default(cuid())
  slug                        String                   @unique
  name                        String
  offerType                   OfferType                @default(StandaloneService)
  category                    ServiceCategory
  shortExplanation            String
  internalExplanation         String
  problemsSolved              String[]
  idealCustomer               String
  includedDeliverables        String[]
  optionalAddOns              String[]
  oneTimePriceCents           Int?
  monthlyPriceCents           Int?
  priceRangeMinCents          Int?
  priceRangeMaxCents          Int?
  setupFeeCents               Int?
  annualFeeCents              Int?
  internalMinimumCents        Int?
  standardPriceCents          Int?
  standardMonthlyPriceCents   Int?
  discountFloorCents          Int?
  targetGrossMargin           Decimal?
  founderSetupHours           Decimal?
  founderMonthlyHours         Decimal?
  contractorSetupHours        Decimal?
  contractorMonthlyHours      Decimal?
  founderHourlyCostCents      Int?
  contractorHourlyCostCents   Int?
  estimatedSetupHours         Decimal?
  estimatedMonthlyHours       Decimal?
  directCostsCents            Int?
  softwareCostsCents          Int?
  apiCostsCents               Int?
  hostingCostsCents           Int?
  dataProviderCostsCents      Int?
  advertisingManagementCents  Int?
  supportReserveCents         Int?
  riskReserveCents            Int?
  paymentProcessingFeePercent Decimal?
  contractorCostsCents        Int?
  noSetupFeeRequired          Boolean                  @default(false)
  reviewPriority              Int                      @default(99)
  reviewPriorityLabel         String?
  changeReason                String?
  pricingStatus               PricingStatus            @default(FounderManagedRequired)
  pricingBasis                PricingBasis?
  priceDisplayMode            PriceDisplayMode         @default(FounderReviewRequired)
  approvedAt                  DateTime?
  approvedById                String?
  approvedBy                  User?                    @relation("ServiceApprovedBy", fields: [approvedById], references: [id])
  reviewDate                  DateTime?
  paymentTerms                String?
  minimumEngagement           String?
  minimumTermMonths           Int?
  cancellationTerms           String?
  earlyCancellationTerms      String?
  buyoutAmountCents           Int?
  typicalTimeline             String?
  qualificationQuestions      String[]
  commonObjections            String[]
  approvedResponse            String
  desiredNextStep             String
  alexMayQuote                Boolean                  @default(false)
  employeeQuotePermission     Boolean                  @default(false)
  founderApprovalRequired     Boolean                  @default(true)
  financingStatus             FinancingStatus          @default(FinancingUnavailable)
  financingNotes              String?
  websiteIncluded             Boolean                  @default(false)
  websiteInclusion            String?
  websiteType                 String?
  pageAllowance               String?
  featureAllowance            String?
  designLevel                 String?
  revisionAllowance           String?
  buildValueCents             Int?
  monthlyRecoveryAmountCents  Int?
  transferEligibility         String?
  ownershipTransferTiming     String?
  websiteOwnershipTerms       String?
  supportLevel                String?
  supportResponseTarget       String?
  reportingFrequency          String?
  meetingFrequency            String?
  scopeAssumptions            String[]                 @default([])
  exclusions                  String[]                 @default([])
  customerFacingNotes         String?
  customerFacingInclusions    String[]                 @default([])
  customerFacingExclusions    String[]                 @default([])
  approvedWording             String?
  escalationTriggers          String[]                 @default([])
  upgradePath                 String?
  downgradePath               String?
  requiredAcknowledgement     String?
  active                      Boolean                  @default(true)
  displayOrder                Int                      @default(0)
  internalNotes               String?
  founderNotes                String?
  pricingNotes                String?
  customPricingFields         Json?
  approvalThreshold           String?
  effectiveDate               DateTime?
  updatedById                 String?
  updatedBy                   User?                    @relation("ServiceUpdatedBy", fields: [updatedById], references: [id])
  pricingTiers                PricingTier[]
  addOns                      ServiceAddOn[]
  recurringFees               RecurringFee[]
  setupFees                   SetupFee[]
  discounts                   ServiceDiscount[]
  pricingHistory              PricingHistory[]
  packageItems                PackageItem[]
  pricingRequests             PricingApprovalRequest[]
  recommendedLeads            Lead[]                   @relation("LeadRecommendedService")
  acknowledgements            PricingAcknowledgement[]
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt
  archivedAt                  DateTime?

  @@index([active, displayOrder])
  @@index([category])
  @@index([offerType, active, displayOrder])
  @@index([pricingStatus])
  @@index([alexMayQuote, founderApprovalRequired])
}

model PricingAcknowledgement {
  id             String          @id @default(cuid())
  userId         String
  serviceId      String
  serviceVersion DateTime
  acknowledgedAt DateTime        @default(now())
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  service        ServiceOffering @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId, serviceVersion])
  @@index([serviceId, acknowledgedAt])
  @@index([userId, acknowledgedAt])
}

model PricingApprovalRequest {
  id                    String           @id @default(cuid())
  leadId                String?
  serviceId             String?
  business              String
  recommendedOffer      String
  currentPain           String
  requestedPricing      String?
  requestedDiscount     String?
  requestedTerm         String?
  requestedAddOns       String?
  competitorInformation String?
  budgetIndication      String?
  recommendation        String
  urgency               Priority         @default(Medium)
  meetingDate           DateTime?
  notes                 String?
  status                ApprovalStatus   @default(Open)
  founderResponse       String?
  conditions            String?
  expiresAt             DateTime?
  requesterId           String
  deciderId             String?
  decisionAt            DateTime?
  lead                  Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  service               ServiceOffering? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  requester             User             @relation("PricingApprovalRequester", fields: [requesterId], references: [id])
  decider               User?            @relation("PricingApprovalDecider", fields: [deciderId], references: [id])
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([leadId, status])
  @@index([serviceId, status])
  @@index([requesterId, status])
}

model PricingTier {
  id            String          @id @default(cuid())
  serviceId     String
  name          String
  description   String?
  priceCents    Int?
  monthlyCents  Int?
  frequency     PriceFrequency?
  includedUsage String?
  active        Boolean         @default(true)
  service       ServiceOffering @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([serviceId, active])
}

model ServiceAddOn {
  id               String          @id @default(cuid())
  serviceId        String
  name             String
  description      String?
  priceCents       Int?
  monthlyCents     Int?
  approvalRequired Boolean         @default(false)
  active           Boolean         @default(true)
  service          ServiceOffering @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([serviceId, active])
}

model RecurringFee {
  id           String          @id @default(cuid())
  serviceId    String
  name         String
  monthlyCents Int?
  notes        String?
  service      ServiceOffering @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())
}

model SetupFee {
  id               String          @id @default(cuid())
  serviceId        String
  name             String
  priceCents       Int?
  approvalRequired Boolean         @default(true)
  notes            String?
  service          ServiceOffering @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
}

model ServiceDiscount {
  id                      String          @id @default(cuid())
  serviceId               String
  name                    String
  maxPercent              Int?
  notes                   String?
  requiresFounderApproval Boolean         @default(true)
  active                  Boolean         @default(true)
  service                 ServiceOffering @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt               DateTime        @default(now())
}

model ServicePackage {
  id                        String        @id @default(cuid())
  slug                      String        @unique
  name                      String
  description               String
  setupPriceCents           Int?
  monthlyPriceCents         Int?
  discount                  String?
  minimumTerm               String?
  paymentSchedule           String?
  includedUsage             String?
  optionalAddOns            String[]
  internalDeliveryCostCents Int?
  employeeQuotePermission   Boolean       @default(false)
  founderApprovalThreshold  String?
  active                    Boolean       @default(false)
  displayOrder              Int           @default(0)
  updatedById               String?
  updatedBy                 User?         @relation("PackageUpdatedBy", fields: [updatedById], references: [id])
  items                     PackageItem[]
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  archivedAt                DateTime?

  @@index([active, displayOrder])
}

model PackageItem {
  id        String          @id @default(cuid())
  packageId String
  serviceId String
  quantity  Int             @default(1)
  notes     String?
  package   ServicePackage  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  service   ServiceOffering @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@unique([packageId, serviceId])
}

model PricingHistory {
  id            String           @id @default(cuid())
  serviceId     String?
  packageId     String?
  changedById   String?
  action        String
  before        Json?
  after         Json?
  effectiveDate DateTime?
  service       ServiceOffering? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  changedBy     User?            @relation("PricingHistoryChangedBy", fields: [changedById], references: [id])
  createdAt     DateTime         @default(now())

  @@index([serviceId, createdAt])
  @@index([packageId, createdAt])
}

model LeadAccess {
  userId    String
  leadId    String
  access    AccessLevel @default(View)
  grantedBy String?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead      Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@id([userId, leadId])
  @@index([leadId])
}

model Project {
  id          String      @id @default(cuid())
  clientId    String?
  name        String
  description String?
  status      String
  timeline    String?
  client      Client?     @relation(fields: [clientId], references: [id])
  tasks       Task[]
  milestones  Milestone[]
  files       FileAsset[]
  comments    Comment[]
  activity    Activity[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  archivedAt  DateTime?
}

model Milestone {
  id        String    @id @default(cuid())
  projectId String
  title     String
  dueDate   DateTime?
  completed Boolean   @default(false)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Task {
  id               String      @id @default(cuid())
  title            String
  description      String?
  status           TaskStatus  @default(New)
  priority         Priority    @default(Medium)
  dueDate          DateTime?
  projectId        String?
  clientId         String?
  leadId           String?
  ownerId          String?
  approverId       String?
  createdById      String?
  approvalRequired Boolean     @default(false)
  internalNotes    String?
  completedAt      DateTime?
  archivedAt       DateTime?
  project          Project?    @relation(fields: [projectId], references: [id])
  client           Client?     @relation(fields: [clientId], references: [id])
  lead             Lead?       @relation(fields: [leadId], references: [id])
  owner            User?       @relation("TaskOwner", fields: [ownerId], references: [id])
  approver         User?       @relation("TaskApprover", fields: [approverId], references: [id])
  createdBy        User?       @relation("TaskCreator", fields: [createdById], references: [id])
  comments         Comment[]
  files            FileAsset[]
  approvals        Approval[]
  activity         Activity[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([ownerId, status])
  @@index([dueDate])
  @@index([clientId])
  @@index([leadId])
}

model OnboardingModule {
  id               String                 @id @default(cuid())
  title            String
  description      String
  content          String
  estimatedMinutes Int
  required         Boolean                @default(true)
  sortOrder        Int
  published        Boolean                @default(true)
  visibleToRoles   RoleName[]             @default([])
  completions      OnboardingCompletion[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([published, sortOrder])
}

model OnboardingCompletion {
  userId      String
  moduleId    String
  completedAt DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  module      OnboardingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([userId, moduleId])
  @@index([userId, completedAt])
}

model LearningPath {
  id                    String                   @id @default(cuid())
  sourceKey             String                   @unique
  slug                  String                   @unique
  title                 String
  description           String
  visibleToRoles        RoleName[]               @default([])
  active                Boolean                  @default(true)
  version               Int                      @default(1)
  estimatedTotalMinutes Int                      @default(0)
  seedManaged           Boolean                  @default(true)
  founderReviewRequired Boolean                  @default(false)
  createdById           String?
  updatedById           String?
  courses               Course[]
  assignments           LearningPathAssignment[]
  progress              AcademyProgress[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  archivedAt            DateTime?

  @@index([active])
}

model LearningPathAssignment {
  id           String                  @id @default(cuid())
  pathId       String
  userId       String
  assignedById String?
  assignedAt   DateTime                @default(now())
  dueDate      DateTime?
  status       AcademyAssignmentStatus @default(Assigned)
  startedAt    DateTime?
  completedAt  DateTime?
  required     Boolean                 @default(true)
  customNotes  String?
  path         LearningPath            @relation(fields: [pathId], references: [id], onDelete: Cascade)
  user         User                    @relation("AcademyLearner", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy   User?                   @relation("AcademyAssigner", fields: [assignedById], references: [id])

  @@unique([pathId, userId])
  @@index([userId, status])
}

model Course {
  id          String         @id @default(cuid())
  sourceKey   String         @unique
  slug        String         @unique
  pathId      String
  title       String
  description String
  sortOrder   Int
  required    Boolean        @default(true)
  published   Boolean        @default(true)
  seedManaged Boolean        @default(true)
  path        LearningPath   @relation(fields: [pathId], references: [id], onDelete: Cascade)
  modules     CourseModule[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([pathId, sortOrder])
}

model CourseModule {
  id                      String                   @id @default(cuid())
  sourceKey               String                   @unique
  slug                    String                   @unique
  courseId                String
  title                   String
  summary                 String
  learningObjectives      String[]
  body                    String
  sortOrder               Int
  estimatedMinutes        Int
  required                Boolean                  @default(true)
  contentType             AcademyContentType       @default(Learning)
  published               Boolean                  @default(true)
  audienceRoles           RoleName[]               @default([])
  version                 Int                      @default(1)
  acknowledgementRequired Boolean                  @default(false)
  acknowledgementText     String?
  knowledgeCheckRequired  Boolean                  @default(false)
  minimumPassingScore     Int                      @default(80)
  ownerId                 String?
  lastReviewed            DateTime?
  nextReviewDate          DateTime?
  founderReviewRequired   Boolean                  @default(false)
  primarySopId            String?
  primarySop              SOPArticle?              @relation("ModulePrimarySOP", fields: [primarySopId], references: [id])
  seedManaged             Boolean                  @default(true)
  archivedAt              DateTime?
  course                  Course                   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sections                ModuleSection[]
  resources               ModuleResource[]
  knowledgeCheck          KnowledgeCheck?
  questionBank            KnowledgeCheckQuestion[]
  completions             ModuleCompletion[]
  acknowledgements        PolicyAcknowledgement[]
  notes                   EmployeeModuleNote[]
  questions               EmployeeQuestion[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@index([courseId, sortOrder])
  @@index([published, contentType])
}

model ModuleSection {
  id        String       @id @default(cuid())
  moduleId  String
  heading   String
  body      String
  sortOrder Int
  module    CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, sortOrder])
}

model ModuleResource {
  id          String             @id @default(cuid())
  moduleId    String
  type        ModuleResourceType
  label       String
  url         String?
  description String?
  sortOrder   Int                @default(0)
  module      CourseModule       @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId, sortOrder])
}

model KnowledgeCheck {
  id               String                        @id @default(cuid())
  moduleId         String                        @unique
  passingScore     Int                           @default(80)
  unlimitedRetries Boolean                       @default(true)
  module           CourseModule                  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions        KnowledgeCheckQuestion[]
  attempts         KnowledgeCheckAttempt[]
  unlocks          KnowledgeCheckAttemptUnlock[]
}

model KnowledgeCheckQuestion {
  id                    String                       @id @default(cuid())
  checkId               String
  moduleId              String?
  sopId                 String?
  learningObjective     String?
  type                  KnowledgeQuestionType
  prompt                String
  explanation           String
  incorrectExplanation  String?
  difficulty            AcademyQuestionDifficulty    @default(Beginner)
  status                AcademyQuestionPublishStatus @default(Approved)
  createdById           String?
  approvedById          String?
  sortOrder             Int
  requiredFounderReview Boolean                      @default(false)
  check                 KnowledgeCheck               @relation(fields: [checkId], references: [id], onDelete: Cascade)
  module                CourseModule?                @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  sop                   SOPArticle?                  @relation(fields: [sopId], references: [id])
  options               KnowledgeCheckOption[]

  @@unique([checkId, sortOrder])
}

model KnowledgeCheckOption {
  id         String                 @id @default(cuid())
  questionId String
  label      String
  correct    Boolean                @default(false)
  sortOrder  Int
  question   KnowledgeCheckQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, sortOrder])
}

model KnowledgeCheckAttempt {
  id            String                 @id @default(cuid())
  checkId       String
  userId        String
  answers       Json
  score         Int
  status        KnowledgeAttemptStatus
  submittedAt   DateTime               @default(now())
  reviewerId    String?
  reviewerNotes String?
  check         KnowledgeCheck         @relation(fields: [checkId], references: [id], onDelete: Cascade)

  @@index([checkId, userId, submittedAt])
}

model KnowledgeCheckAttemptUnlock {
  id           String         @id @default(cuid())
  checkId      String
  userId       String
  unlockedById String
  reason       String?
  usedAt       DateTime?
  createdAt    DateTime       @default(now())
  check        KnowledgeCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)
  user         User           @relation("KnowledgeCheckUnlockLearner", fields: [userId], references: [id], onDelete: Cascade)
  unlockedBy   User           @relation("KnowledgeCheckUnlockManager", fields: [unlockedById], references: [id])

  @@index([checkId, userId, usedAt])
  @@index([unlockedById, createdAt])
}

model ModuleCompletion {
  id                      String       @id @default(cuid())
  userId                  String
  moduleId                String
  moduleVersion           Int
  acknowledgementAccepted Boolean      @default(false)
  knowledgeCheckAttemptId String?
  founderReviewedAt       DateTime?
  completedAt             DateTime     @default(now())
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  module                  CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId, moduleVersion])
  @@index([userId, completedAt])
}

model PolicyAcknowledgement {
  id             String       @id @default(cuid())
  userId         String
  moduleId       String
  moduleVersion  Int
  statement      String
  acknowledgedAt DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  module         CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId, moduleVersion])
}

model EmployeeModuleNote {
  id        String       @id @default(cuid())
  userId    String
  moduleId  String
  body      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  module    CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model EmployeeQuestion {
  id               String                @id @default(cuid())
  userId           String
  moduleId         String?
  urgency          AcademyUrgency        @default(Normal)
  status           AcademyQuestionStatus @default(Open)
  question         String
  answer           String?
  answeredById     String?
  answeredAt       DateTime?
  resolvedAt       DateTime?
  convertedToFaqAt DateTime?
  user             User                  @relation("AcademyQuestionLearner", fields: [userId], references: [id], onDelete: Cascade)
  answeredBy       User?                 @relation("AcademyQuestionAnswerer", fields: [answeredById], references: [id])
  module           CourseModule?         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([userId, status])
  @@index([moduleId, status])
}

model SOPArticle {
  id                    String                   @id @default(cuid())
  sourceKey             String                   @unique
  slug                  String                   @unique
  title                 String
  category              SOPCategory
  purpose               String
  owner                 String
  audienceRoles         RoleName[]               @default([])
  trigger               String
  requiredInputs        String[]
  body                  String
  approvalPoints        String[]
  escalationConditions  String[]
  completionCriteria    String[]
  relatedTemplates      String[]
  version               Int                      @default(1)
  published             Boolean                  @default(true)
  seedManaged           Boolean                  @default(true)
  founderReviewRequired Boolean                  @default(false)
  lastReviewed          DateTime?
  nextReviewDate        DateTime?
  steps                 SOPStep[]
  primaryForModules     CourseModule[]           @relation("ModulePrimarySOP")
  knowledgeQuestions    KnowledgeCheckQuestion[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  archivedAt            DateTime?

  @@index([published, category])
}

model WorkShift {
  id               String                  @id @default(cuid())
  userId           String
  startedAt        DateTime
  endedAt          DateTime?
  grossMinutes     Int?
  breakMinutes     Int                     @default(0)
  netMinutes       Int?
  status           WorkShiftStatus         @default(ClockedIn)
  correctionStatus TimeCorrectionStatus?
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  breaks           WorkBreak[]
  corrections      TimeCorrectionRequest[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([userId, status])
  @@index([startedAt])
}

model WorkBreak {
  id              String    @id @default(cuid())
  shiftId         String
  startedAt       DateTime
  endedAt         DateTime?
  durationMinutes Int?
  note            String?
  shift           WorkShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([shiftId, startedAt])
}

model TimeCorrectionRequest {
  id                     String               @id @default(cuid())
  shiftId                String?
  requesterId            String
  requestedStartTime     DateTime?
  requestedEndTime       DateTime?
  requestedBreakDuration Int?
  reason                 String
  supportingNote         String?
  status                 TimeCorrectionStatus @default(Requested)
  founderComment         String?
  reviewedById           String?
  reviewedAt             DateTime?
  shift                  WorkShift?           @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  requester              User                 @relation("TimeCorrectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewedBy             User?                @relation("TimeCorrectionReviewer", fields: [reviewedById], references: [id])
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([requesterId, status])
  @@index([shiftId])
}

model SOPStep {
  id          String     @id @default(cuid())
  sopId       String
  stepNumber  Int
  title       String
  instruction String
  sop         SOPArticle @relation(fields: [sopId], references: [id], onDelete: Cascade)

  @@unique([sopId, stepNumber])
}

model KnowledgeArticleVersion {
  id          String           @id @default(cuid())
  articleId   String
  version     Int
  title       String
  body        String
  changedById String?
  article     KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@unique([articleId, version])
}

model ContentAudience {
  id          String   @id @default(cuid())
  contentType String
  contentId   String
  role        RoleName
  required    Boolean  @default(false)

  @@unique([contentType, contentId, role])
  @@index([role])
}

model RequiredReadingAssignment {
  id           String    @id @default(cuid())
  userId       String
  contentType  String
  contentId    String
  assignedById String?
  dueDate      DateTime?
  completedAt  DateTime?
  required     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@unique([userId, contentType, contentId])
  @@index([userId, completedAt])
}

model AcademyProgress {
  id                        String       @id @default(cuid())
  userId                    String
  pathId                    String
  percent                   Int          @default(0)
  estimatedMinutesRemaining Int          @default(0)
  updatedAt                 DateTime     @updatedAt
  user                      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  path                      LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@unique([userId, pathId])
}

model AcademyActivity {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  targetType String
  targetId   String?
  target     String
  metadata   Json?
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}

model KnowledgeArticle {
  id              String                    @id @default(cuid())
  title           String
  category        String
  body            String
  status          KnowledgeStatus           @default(Draft)
  ownerId         String?
  version         Int                       @default(1)
  visibleToRoles  RoleName[]
  requiredReading Boolean                   @default(false)
  relatedLinks    Json?
  archivedAt      DateTime?
  owner           User?                     @relation(fields: [ownerId], references: [id])
  versions        KnowledgeArticleVersion[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([status, category])
}

model FileAsset {
  id         String              @id @default(cuid())
  name       String
  mimeType   String
  size       Int
  storageKey String
  visibility FileVisibility      @default(AssignedUsers)
  folder     String
  version    Int                 @default(1)
  uploaderId String
  clientId   String?
  leadId     String?
  projectId  String?
  taskId     String?
  approvalId String?
  reportId   String?
  feedbackId String?
  uploader   User                @relation(fields: [uploaderId], references: [id])
  client     Client?             @relation(fields: [clientId], references: [id])
  lead       Lead?               @relation(fields: [leadId], references: [id])
  project    Project?            @relation(fields: [projectId], references: [id])
  task       Task?               @relation(fields: [taskId], references: [id])
  approval   Approval?           @relation(fields: [approvalId], references: [id])
  report     DailyReport?        @relation(fields: [reportId], references: [id])
  feedback   FeedbackSubmission? @relation(fields: [feedbackId], references: [id])
  access     FileAccess[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  archivedAt DateTime?
}

model FileAccess {
  userId String
  fileId String
  access AccessLevel @default(View)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  file   FileAsset   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([userId, fileId])
}

model DailyReport {
  id                 String            @id @default(cuid())
  userId             String
  reportDate         DateTime
  shiftStart         DateTime?
  shiftEnd           DateTime?
  breakMinutes       Int               @default(0)
  hoursWorked        Decimal
  completed          String
  inProgress         String
  clientUpdates      String?
  leadActivity       String?
  meetings           String?
  blockers           String?
  waitingOnStephen   String?
  recommendations    String?
  tomorrowPriorities String
  status             DailyReportStatus @default(Draft)
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewerId         String?
  reviewerNotes      String?
  user               User              @relation(fields: [userId], references: [id])
  reviewer           User?             @relation("ReportReviewer", fields: [reviewerId], references: [id])
  files              FileAsset[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([userId, reportDate])
  @@index([userId, reportDate])
  @@index([status])
}

model Approval {
  id                   String              @id @default(cuid())
  summary              String
  context              String
  businessImpact       String
  recommendation       String
  deadline             DateTime?
  priority             Priority            @default(Medium)
  status               ApprovalStatus      @default(Open)
  decision             String?
  decisionNotes        String?
  decisionAt           DateTime?
  requesterId          String
  deciderId            String?
  taskId               String?
  clientId             String?
  leadId               String?
  draftCommunicationId String?
  requester            User                @relation("ApprovalRequester", fields: [requesterId], references: [id])
  decider              User?               @relation("ApprovalDecider", fields: [deciderId], references: [id])
  task                 Task?               @relation(fields: [taskId], references: [id])
  client               Client?             @relation(fields: [clientId], references: [id])
  lead                 Lead?               @relation(fields: [leadId], references: [id])
  draftCommunication   DraftCommunication? @relation(fields: [draftCommunicationId], references: [id])
  comments             Comment[]
  files                FileAsset[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([status, deadline])
  @@index([requesterId])
}

model DraftCommunication {
  id               String                   @id @default(cuid())
  authorId         String
  clientId         String?
  leadId           String?
  channel          String
  recipient        String
  subject          String?
  body             String
  purpose          String
  status           DraftCommunicationStatus @default(Draft)
  approverId       String?
  approvalComments String?
  approvedAt       DateTime?
  sentAt           DateTime?
  sentById         String?
  outcome          String?
  author           User                     @relation("DraftAuthor", fields: [authorId], references: [id])
  client           Client?                  @relation(fields: [clientId], references: [id])
  lead             Lead?                    @relation(fields: [leadId], references: [id])
  approver         User?                    @relation("DraftApprover", fields: [approverId], references: [id])
  sentBy           User?                    @relation("DraftSender", fields: [sentById], references: [id])
  approvals        Approval[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

model Announcement {
  id            String             @id @default(cuid())
  title         String
  body          String
  category      String
  priority      Priority           @default(Medium)
  pinned        Boolean            @default(false)
  publishAt     DateTime           @default(now())
  expiresAt     DateTime?
  audienceRoles RoleName[]
  archivedAt    DateTime?
  authorId      String
  author        User               @relation(fields: [authorId], references: [id])
  readReceipts  AnnouncementRead[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model AnnouncementRead {
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([announcementId, userId])
}

model FeedbackSubmission {
  id                 String         @id @default(cuid())
  supportKey         String?        @unique
  type               FeedbackType
  title              String
  description        String
  pageOrFeature      String?
  missionControlArea String?
  expectedResult     String?
  actualResult       String?
  workaroundTried    String?
  blocked            Boolean        @default(false)
  severity           Priority       @default(Medium)
  attachmentId       String?
  submittedById      String
  status             FeedbackStatus @default(New)
  agentSummary       String?
  founderResponse    String?
  resolutionNotes    String?
  resolvedAt         DateTime?
  submittedBy        User           @relation(fields: [submittedById], references: [id])
  files              FileAsset[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([status, severity, createdAt])
  @@index([submittedById, status])
}

model TrialSettings {
