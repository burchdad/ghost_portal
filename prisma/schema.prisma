  @@index([userId, createdAt])
}

model Communication {
  id         String   @id @default(cuid())
  clientId   String
  channel    String
  summary    String
  occurredAt DateTime
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}
